        </button>
      </div>
      <div id="resultadosContent"></div>
    </div>

    <div id="adminTabPuntos" style="display:none">
      <div id="puntosContent">
        <div class="empty-state"><div class="emoji">⏳</div><p>Cargando puntuación…</p></div>
      </div>
    </div>
  </div>
</div>

</div><!-- /main -->

