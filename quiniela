<!-- Firebase SDK -->
<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
  import { getFirestore, doc, setDoc, getDoc, getDocs, deleteDoc, collection, serverTimestamp }
    from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

  // ─── FIREBASE CONFIG ────────────────────────────────────────────
  // INSTRUCCIONES PARA MAURICIO:
  // 1. Ve a https://console.firebase.google.com
  // 2. Crea proyecto "quiniela-rodriguez-2026"
  // 3. Firestore Database → Crear en modo prueba
  // 4. Configuración del proyecto → Agregar app web
  // 5. Copia tu firebaseConfig y pégalo aquí abajo:
  const firebaseConfig = {
    apiKey: "AIzaSyCeeZL8RlxrXLPBg6hByXxI9ZEyFajPY1w",
    authDomain: "quiniela-rodriguez-2026.firebaseapp.com",
    projectId: "quiniela-rodriguez-2026",
    storageBucket: "quiniela-rodriguez-2026.firebasestorage.app",
    messagingSenderId: "1077314022638",
    appId: "1:1077314022638:web:728b34388dbc7aa48f17ff",
    measurementId: "G-C9BVX6SYZW"
  };
  // ────────────────────────────────────────────────────────────────

  const app = initializeApp(firebaseConfig);
  const db  = getFirestore(app);

  // Normaliza un nombre a un ID estable: sin acentos, sin espacios extra, minúsculas
  function normalizeId(nombre) {
    return nombre
      .trim()
      .toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g,'') // quitar acentos
      .replace(/\s+/g,'_')
      .replace(/[^a-z0-9_]/g,''); // quitar caracteres raros
  }
  window._fb = {
    normalizeId,
    async guardar(nombre, data) {
      const id = normalizeId(nombre);
      // Guardar historial: snapshot previo antes de sobrescribir
      try {
        const prevSnap = await getDoc(doc(db, 'quinielas', id));
        if (prevSnap.exists()) {
          const histId = id + '__' + Date.now();
          await setDoc(doc(db, 'historial', histId), {
            participante: prevSnap.data().participante,
            data: prevSnap.data().data,
            savedAt: serverTimestamp()
          });
        }
      } catch(e) { console.warn('No se pudo guardar historial:', e); }

      await setDoc(doc(db, 'quinielas', id), {
        participante: nombre.trim(),
        data,
        updatedAt: serverTimestamp()
      });
      return id;
    },
    async cargar(nombre) {
      const id = normalizeId(nombre);
      let snap = await getDoc(doc(db, 'quinielas', id));
      if (snap.exists()) return snap.data();

      // Fallback de migración única: el documento pudo haberse guardado
      // antes de normalizar (con acentos). Coincidencia EXACTA solamente
      // (mismo texto, solo difiere en acentos/mayúsculas) para evitar
      // mezclar accidentalmente la quiniela de dos personas distintas.
      const nombreNorm = nombre.trim().toLowerCase();
      const allDocs = await getDocs(collection(db, 'quinielas'));
      let found = null, foundId = null;
      allDocs.forEach(d => {
        if (found) return;
        const data = d.data();
        const dataNombreNorm = (data.participante||'').trim().toLowerCase();
        if (dataNombreNorm === nombreNorm) { found = data; foundId = d.id; }
      });

      if (found && foundId !== id) {
        // Auto-migrar UNA SOLA VEZ al ID nuevo normalizado
        await setDoc(doc(db, 'quinielas', id), {
          participante: nombre.trim(),
          data: found.data,
          updatedAt: serverTimestamp()
        });
        console.log(`Migrado automáticamente: ${foundId} → ${id}`);
        return found;
      }
      return found || null;
    },
    async listarTodos() {
      const snap = await getDocs(collection(db, 'quinielas'));
      return snap.docs.map(d => ({ id: d.id, ...d.data() }));
    },
    async eliminar(id) {
      await deleteDoc(doc(db, 'quinielas', id));
    },
    async listarHistorial(nombre) {
      const id = normalizeId(nombre);
      const snap = await getDocs(collection(db, 'historial'));
      return snap.docs
        .map(d => ({ id: d.id, ...d.data() }))
        .filter(h => h.id.startsWith(id + '__'))
        .sort((a,b) => (b.savedAt?.seconds||0) - (a.savedAt?.seconds||0));
    },
    async restaurarHistorial(histId, nombre) {
      const histSnap = await getDoc(doc(db, 'historial', histId));
      if (!histSnap.exists()) throw new Error('Versión no encontrada');
      const id = normalizeId(nombre);
      await setDoc(doc(db, 'quinielas', id), {
        participante: nombre,
        data: histSnap.data().data,
        updatedAt: serverTimestamp()
      });
    }
  };

  // Guardar/cargar resultados reales (colección separada)
  window._fb.guardarResultados = async function(data) {
    await setDoc(doc(db, 'config', 'resultados'), { data, updatedAt: serverTimestamp() });
  };
  window._fb.cargarResultados = async function() {
    const snap = await getDoc(doc(db, 'config', 'resultados'));
    return snap.exists() ? snap.data().data : {};
  };
  // Bracket eliminatorio definido por admin
  window._fb.guardarBracket = async function(data) {
    await setDoc(doc(db, 'config', 'bracket'), { data, updatedAt: serverTimestamp() });
  };
  window._fb.cargarBracket = async function() {
    const snap = await getDoc(doc(db, 'config', 'bracket'));
    return snap.exists() ? snap.data().data : {};
  };

  // Avisar que Firebase está listo
  document.dispatchEvent(new Event('fb-ready'));
</script>

