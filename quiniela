    const penId = `pen_${prefix_i}`;

    const vL  = state[kL]  ?? '';
    const vV  = state[kV]  ?? '';
    const vG  = state[kg]  ?? '';
    const vPen= state[kPen]?? '';

    // Determine if teams are fixed (r32) or open
    const teamAFixed = p.a || null;
    const teamBFixed = p.b || null;
    const currentA = teamAFixed || state[`${prefix_i}_1`] || '';
    const currentB = teamBFixed || state[`${prefix_i}_2`] || '';

    // Lock by datetime
    const locked = p.dt ? isLocked(p.dt) : false;
    const dtLabel = p.dt ? fmtDT(p.dt) : null;

    // Is it a tie? Show penalty dropdown
    const isTie = vL !== '' && vV !== '' && parseInt(vL) === parseInt(vV) && !isNaN(parseInt(vL));

    // Options for penalty dropdown — only the 2 teams of this match
    const penOpts = `<option value="">— ¿Quién gana? —</option>` +
      [currentA, currentB].filter(Boolean).map(e =>
        `<option value="${e}">${flagFor(e)} ${e}</option>`).join('');

    // Group badge
    const gBadge = p.g ? `<span style="font-size:9px;padding:2px 6px;border-radius:3px;font-weight:700;
      background:${p.g===1?'rgba(68,138,255,.15)':'rgba(0,200,83,.12)'};
      color:${p.g===1?'#448aff':'var(--verde)'}">Grupo ${p.g}</span>` : '';

    const card = document.createElement('div');
    card.className = 'partido-card';
    card.style.borderColor = p.g ? (p.g===1 ? 'rgba(68,138,255,.2)' : 'rgba(0,200,83,.15)') : '';

    card.innerHTML = `
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:7px">
        <span class="partido-label" style="margin:0">${p.label||'Partido '+(i+1)}</span>
        ${gBadge}
      </div>
      ${dtLabel ? `<div class="partido-dt">${locked?'🔒 ':''}${dtLabel}${locked?' · <span style="color:#f55;font-size:9px">CERRADO</span>':''}</div>` : ''}
      ${p.hint ? `<div style="font-size:9px;color:var(--gris);margin-bottom:6px;font-style:italic">${p.hint}</div>` : ''}

      <!-- Equipos con marcador -->
      <div style="display:flex;align-items:center;gap:5px;margin-bottom:5px">
        <div style="flex:1;display:flex;align-items:center;gap:5px;font-size:12px;font-weight:700;min-width:0">
          <span>${flagFor(currentA||'?')}</span>
          <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:${currentA?'inherit':'var(--gris)'}">${currentA||'Por definir'}</span>
        </div>
        <div class="score-box" style="flex-shrink:0">
          <input class="score-input" type="number" min="0" max="20" value="${vL}" placeholder="–"
            ${locked?'disabled':''}
            oninput="setElimScoreNew('${kL}','${kV}','${bid}','${penId}',this.value,false,'${prefix_i}')">
          <span class="score-sep">:</span>
          <input class="score-input" type="number" min="0" max="20" value="${vV}" placeholder="–"
            ${locked?'disabled':''}
            oninput="setElimScoreNew('${kV}','${kL}','${bid}','${penId}',this.value,true,'${prefix_i}')">
        </div>
        <div style="flex:1;display:flex;align-items:center;justify-content:flex-end;gap:5px;font-size:12px;font-weight:700;min-width:0">
          <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;text-align:right;color:${currentB?'inherit':'var(--gris)'}">${currentB||'Por definir'}</span>
          <span>${flagFor(currentB||'?')}</span>
        </div>
      </div>

      <!-- Badge resultado -->
      <div id="${bid}" style="margin-bottom:5px">${getElimBadge(vL,vV)}</div>

      <!-- Penales (solo si empate) -->
      <div id="${penId}" style="${isTie?'':'display:none'}">
        <div class="partido-label" style="margin-bottom:4px;color:var(--dorado)">🥅 ¿Quién gana en penales?</div>
        <select class="select-equipo" style="border-color:rgba(255,214,0,.4)"
          onchange="setVal('${kPen}',this.value);setVal('${kg}',this.value)"
          ${locked?'disabled':''}>${penOpts}</select>
      </div>

      <!-- Sin el dropdown de Avanza: cuando no es empate, el ganador
           se infiere del marcador. Solo penales define quién avanza en caso de empate. -->
      <div id="gan_${prefix_i}" style="display:none"></div>`;

    grid.appendChild(card);

    // Restore select values
    if (!teamAFixed) {
      const s = card.querySelectorAll('select')[0];
      if (s && state[`${prefix_i}_1`]) s.value = state[`${prefix_i}_1`];
    }
    if (!teamBFixed) {
      const idx2 = teamAFixed ? 0 : 1;
      const s = card.querySelectorAll('select')[idx2];
      if (s && state[`${prefix_i}_2`]) s.value = state[`${prefix_i}_2`];
    }
    // Restore ganador selects
    const ganSel = card.querySelector(`#gan_${prefix_i} select`);
    if (ganSel && vG && !isTie) ganSel.value = vG;
    const penSel = card.querySelector(`#pen_${prefix_i} select`);
    if (penSel && vPen && isTie) penSel.value = vPen;
  });
}

function getElimBadge(vL, vV) {
  if (vL===''||vV==='') return '';
  const l=parseInt(vL), v=parseInt(vV);
  if (isNaN(l)||isNaN(v)) return '';
  if (l>v) return `<span class="resultado-badge badge-local">← Gana local</span>`;
  if (v>l) return `<span class="resultado-badge badge-visita">Gana visita →</span>`;
  return `<span class="resultado-badge badge-empate">Empate · decide penales ↓</span>`;
}

