function populateCampeonSelect(){
  const sel=document.getElementById('campeonSelect');
  // Include repechaje teams that may not appear in GRUPOS list
  const grupoTeams = GRUPOS.flatMap(g=>g.e.map(e=>e.n));
  const all=[...new Set([...grupoTeams])].sort();
  sel.innerHTML=`<option value="">— Elige al campeón —</option>`+all.map(e=>`<option value="${e}">${e}</option>`).join('');
  if(state.campeon) sel.value=state.campeon;
  updateCampeon();
}
function updateCampeon(){
  const val=document.getElementById('campeonSelect').value;
  state.campeon=val;
  localStorage.setItem('q2026_local',JSON.stringify(state));
  const div=document.getElementById('campeonResult');
  if(val){
    const eq=GRUPOS.flatMap(g=>g.e).find(e=>e.n===val);
    div.textContent=`${eq?eq.f:'🏆'} ${val}`;
    div.classList.add('visible');
  } else div.classList.remove('visible');
  updateProgress();
}

// ══════════════════════════════════════════════════════
// PROGRESO
// ══════════════════════════════════════════════════════
function updateProgress(){
  let total=0,filled=0;
  GRUPOS.forEach(g=>g.p.forEach((p,pi)=>{
    total++;
    const kL=`g${g.l}_${pi}_L`, kV=`g${g.l}_${pi}_V`;
    if(state[kL]!==undefined&&state[kL]!==''&&state[kV]!==undefined&&state[kV]!=='') filled++;
  }));
  total++; if(state.campeon) filled++;
  document.getElementById('progressFill').style.width=Math.round((filled/total)*100)+'%';
}

