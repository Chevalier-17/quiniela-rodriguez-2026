function isLocked(dtStr) {
  if (adminOverrideMode) return false; // admin bypass
  const matchTime = new Date(dtStr + '-06:00');
  return new Date() >= matchTime;
}

function fmt12(d) {
  let h = d.getHours(), m = d.getMinutes();
  const ampm = h >= 12 ? 'p.m.' : 'a.m.';
  h = h % 12 || 12;
  return `${h}:${String(m).padStart(2,'0')} ${ampm}`;
}
function fmtDT(dtStr) {
  const d = new Date(dtStr + '-06:00');
  const dias = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
  const meses = ['ene','feb','mar','abr','may','jun','jul','ago','sep','oct','nov','dic'];
  return `${dias[d.getDay()]} ${d.getDate()} ${meses[d.getMonth()]} · ${fmt12(d)}`;
}

