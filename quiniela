  const allTeams = [...new Set([...allElim, ...allGroups])].sort();
  const opts = `<option value="">— Equipo —</option>` + allTeams.map(e =>
    `<option value="${e}">${flagFor(e)} ${e}</option>`).join('');

  // Group separator colors
  const grpColor = {1:'rgba(68,138,255,.08)', 2:'rgba(0,200,83,.06)'};

  partidos.forEach((p, i) => {
    const prefix_i = `${prefix}_${i}`;
    const kL  = `${prefix_i}_sL`;   // goles local
    const kV  = `${prefix_i}_sV`;   // goles visita
    const kg  = `${prefix_i}_g`;    // ganador (incluyendo penales)
    const kPen= `${prefix_i}_pen`;  // ganador penales (si empate)
