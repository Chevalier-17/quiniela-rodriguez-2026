}

async function adminVerHistorial(nombre){
  if(!fbReady) return;
  try {
    const hist = await window._fb.listarHistorial(nombre);
    let html = `<div class="modal-title">Historial · ${nombre}</div>
      <div class="modal-sub">Versiones anteriores guardadas (más reciente primero)</div>`;
    if (!hist.length) {
      html += `<div class="empty-state"><div class="emoji">📭</div><p>No hay versiones anteriores guardadas para ${nombre}.</p></div>`;
    } else {
      hist.forEach((h,i) => {
        const fecha = h.savedAt?.seconds
          ? new Date(h.savedAt.seconds*1000).toLocaleString('es-MX',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'})
          : '—';
        const d = h.data||{};
        let marcadores=0;
        GRUPOS.forEach(g=>g.p.forEach((p,pi)=>{
          if(d[`g${g.l}_${pi}_L`]!==undefined&&d[`g${g.l}_${pi}_L`]!==''&&d[`g${g.l}_${pi}_V`]!==undefined&&d[`g${g.l}_${pi}_V`]!=='') marcadores++;
        }));
        html += `<div class="q-partido-row" style="justify-content:space-between">
          <span>🕐 ${fecha}</span>
          <span style="color:var(--gris);font-size:11px">${marcadores}/72 marcadores · campeón: ${d.campeon||'—'}</span>
          <button class="btn-ver" onclick="adminRestaurarHistorial('${h.id}','${nombre}')">↩️ Restaurar</button>
        </div>`;
      });
    }
    document.getElementById('modalContent').innerHTML = html;
    document.getElementById('modalOverlay').classList.add('open');
  } catch(e) {
    showToast('Error: '+e.message,'error');
  }
}

async function adminRestaurarHistorial(histId, nombre){
  if(!confirm(`¿Restaurar esta versión de ${nombre}? Esto sobrescribirá su quiniela actual en la nube con esta versión anterior.`)) return;
  try {
    await window._fb.restaurarHistorial(histId, nombre);
    showToast(`✅ Versión restaurada para ${nombre}`);
    document.getElementById('modalOverlay').classList.remove('open');
    adminCargar();
  } catch(e) {
    showToast('Error: '+e.message,'error');
  }
}

