// ══════════════════════════════════════════════════════
// AUTO-PROPAGACIÓN: calcula ganadores del bracket y
// actualiza BRACKET en Firebase para que todos lo vean
// ══════════════════════════════════════════════════════

// Mapa de propagación: [fromPrefix, fromIdx] → [toPrefix, toIdx, slot ('a'|'b')]
// ══════════════════════════════════════════════════════
// MAPA DE PROPAGACIÓN CORREGIDO
// Basado en el bracket oficial:
// r32 índices (orden en BRACKET.r32):
//  G1: 0=RSA/CAN, 1=GER/PAR, 2=NED/MAR, 3=FRA/SWE
//      4=USA/BIH, 5=BEL/SEN, 6=POR/CRO, 7=ESP/AUT
//  G2: 8=BRA/JPN, 9=CIV/NOR, 10=MEX/ECU, 11=ENG/COD
//      12=SUI/ALG, 13=ARG/CPV, 14=COL/GHA, 15=AUS/EGY
//
// r16 (Octavos) según bracket imagen:
//  P89: W74(GER/PAR=r32_1) vs W77(FRA/SWE=r32_3) → r16_0
//  P90: W73(RSA/CAN=r32_0) vs W75(NED/MAR=r32_2) → r16_1
//  P93: W83(POR/CRO=r32_6) vs W84(ESP/AUT=r32_7) → r16_2
//  P94: W81(USA/BIH=r32_4) vs W82(BEL/SEN=r32_5) → r16_3
//  P91: W76(BRA/JPN=r32_8) vs W78(CIV/NOR=r32_9) → r16_4
//  P92: W79(MEX/ECU=r32_10) vs W80(ENG/COD=r32_11) → r16_5
//  P95: W86(ARG/CPV=r32_13) vs W88(AUS/EGY=r32_15) → r16_6
//  P96: W85(SUI/ALG=r32_12) vs W87(COL/GHA=r32_14) → r16_7
//
// qf (Cuartos):
//  P97: W89(r16_0) vs W90(r16_1) → qf_0
//  P98: W93(r16_2) vs W94(r16_3) → qf_1
//  P99: W91(r16_4) vs W92(r16_5) → qf_2
//  P100:W95(r16_6) vs W96(r16_7) → qf_3
//
// sf (Semis):
//  P101: W97(qf_0) vs W98(qf_1) → sf_0
//  P102: W99(qf_2) vs W100(qf_3) → sf_1
//
// final:
//  P103 (3er lugar): RU101(sf_0 perdedor) vs RU102(sf_1 perdedor) → fin_0
//  P104 (Final):     W101(sf_0 ganador)   vs W102(sf_1 ganador)   → fin_1
// ══════════════════════════════════════════════════════
const BRACKET_PROPAGATION = [
  // r32 → r16  [fromPfx, fromIdx, toPfx, toIdx, slot, isLoser]
  ['r32', 1, 'r16', 0, 'a', false],  // GER/PAR → Oct P89 local
  ['r32', 3, 'r16', 0, 'b', false],  // FRA/SWE → Oct P89 visita
  ['r32', 0, 'r16', 1, 'a', false],  // RSA/CAN → Oct P90 local
  ['r32', 2, 'r16', 1, 'b', false],  // NED/MAR → Oct P90 visita
  ['r32', 6, 'r16', 2, 'a', false],  // POR/CRO → Oct P93 local
  ['r32', 7, 'r16', 2, 'b', false],  // ESP/AUT → Oct P93 visita
  ['r32', 4, 'r16', 3, 'a', false],  // USA/BIH → Oct P94 local
  ['r32', 5, 'r16', 3, 'b', false],  // BEL/SEN → Oct P94 visita
  ['r32', 8, 'r16', 4, 'a', false],  // BRA/JPN → Oct P91 local
  ['r32', 9, 'r16', 4, 'b', false],  // CIV/NOR → Oct P91 visita
  ['r32',10, 'r16', 5, 'a', false],  // MEX/ECU → Oct P92 local
  ['r32',11, 'r16', 5, 'b', false],  // ENG/COD → Oct P92 visita
  ['r32',13, 'r16', 6, 'a', false],  // ARG/CPV → Oct P95 local
  ['r32',15, 'r16', 6, 'b', false],  // AUS/EGY → Oct P95 visita
  ['r32',12, 'r16', 7, 'a', false],  // SUI/ALG → Oct P96 local
  ['r32',14, 'r16', 7, 'b', false],  // COL/GHA → Oct P96 visita
  // r16 → qf
  ['r16', 0, 'qf', 0, 'a', false],
  ['r16', 1, 'qf', 0, 'b', false],
  ['r16', 2, 'qf', 1, 'a', false],
  ['r16', 3, 'qf', 1, 'b', false],
  ['r16', 4, 'qf', 2, 'a', false],
  ['r16', 5, 'qf', 2, 'b', false],
  ['r16', 6, 'qf', 3, 'a', false],
  ['r16', 7, 'qf', 3, 'b', false],
  // qf → sf
  ['qf', 0, 'sf', 0, 'a', false],
  ['qf', 1, 'sf', 0, 'b', false],
  ['qf', 2, 'sf', 1, 'a', false],
  ['qf', 3, 'sf', 1, 'b', false],
  // sf → fin_1 (final: ganadores)
  ['sf', 0, 'fin', 1, 'a', false],
  ['sf', 1, 'fin', 1, 'b', false],
  // sf → fin_0 (3er lugar: perdedores)
  ['sf', 0, 'fin', 0, 'a', true],
  ['sf', 1, 'fin', 0, 'b', true],
];

// Get winner of a match from resultadosReales
function getWinnerFromResultados(prefix, idx) {
  const key = `${prefix}_${idx}`;
  const real = resultadosReales[key];
  if (!real) return null;
  const gL = parseInt(real.gL ?? '');
  const gV = parseInt(real.gV ?? '');
  if (isNaN(gL) || isNaN(gV)) return null;
  if (gL !== gV) {
    // Get team names
    const rondaMap = {r32: BRACKET.r32, r16: BRACKET.r16, qf: BRACKET.qf, sf: BRACKET.sf, fin: BRACKET.final};
    const partido = rondaMap[prefix]?.[idx];
    const tA = partido?.a || resultadosReales[key + '_teamA'] || null;
    const tB = partido?.b || resultadosReales[key + '_teamB'] || null;
    return gL > gV ? tA : tB;
  }
  // Empate → ganador de penales
  return real.ganador || null;
}

function getLoserFromResultados(prefix, idx) {
  const winner = getWinnerFromResultados(prefix, idx);
  if (!winner) return null;
  const key = `${prefix}_${idx}`;
  const rondaMap = {r32: BRACKET.r32, r16: BRACKET.r16, qf: BRACKET.qf, sf: BRACKET.sf, fin: BRACKET.final};
  const partido = rondaMap[prefix]?.[idx];
  const tA = partido?.a || resultadosReales[key + '_teamA'] || null;
  const tB = partido?.b || resultadosReales[key + '_teamB'] || null;
  if (winner === tA) return tB;
  if (winner === tB) return tA;
  return null;
}

async function propagarBracket() {
  let changed = false;
  const rondaMap = {r32: BRACKET.r32, r16: BRACKET.r16, qf: BRACKET.qf, sf: BRACKET.sf, fin: BRACKET.final};

  BRACKET_PROPAGATION.forEach(([fromPfx, fromIdx, toPfx, toIdx, slot, isLoser]) => {
    const team = isLoser
      ? getLoserFromResultados(fromPfx, fromIdx)
      : getWinnerFromResultados(fromPfx, fromIdx);

    const partido = rondaMap[toPfx]?.[toIdx];
    if (!partido) return;

    const currentVal = slot === 'a' ? partido.a : partido.b;
    const newVal = team || null; // null si no hay resultado → deja slot vacío

    if (currentVal !== newVal) {
      if (slot === 'a') partido.a = newVal;
      else partido.b = newVal;
      changed = true;
    }
  });

  // Siempre guardar (aunque no haya changed) para sincronizar nulos
  try {
    const bracketData = {
      r32: BRACKET.r32, r16: BRACKET.r16,
      qf: BRACKET.qf, sf: BRACKET.sf, final: BRACKET.final,
    };
    if (window._fb?.guardarBracket) await window._fb.guardarBracket(bracketData);
    renderEliminatorias();
    if (changed) showToast('⚽ Bracket actualizado');
  } catch(e) {
    console.error('Error guardando bracket:', e);
  }
}

async function cargarBracketDesdeNube() {
  try {
    if (!window._fb?.cargarBracket) return;
    const data = await window._fb.cargarBracket();
    if (!data) return;
    // Merge open rounds (r16 onward) — apply all values including null
    ['r16','qf','sf','final'].forEach(ronda => {
      if (data[ronda]) {
        data[ronda].forEach((p, i) => {
          if (BRACKET[ronda]?.[i]) {
            // Apply a/b regardless of null (null = no result yet = "Por definir")
            if ('a' in p) BRACKET[ronda][i].a = p.a || null;
            if ('b' in p) BRACKET[ronda][i].b = p.b || null;
            if (p.dt)     BRACKET[ronda][i].dt = p.dt;
          }
        });
      }
    });
    renderEliminatorias();
  } catch(e) { console.warn('No se pudo cargar bracket:', e); }
}

