// Recuperar quiniela propia desde Firebase
async function cargarDesdeNube(silent=false){
  const nombre = document.getElementById('participanteInput').value.trim();
  if(!nombre){ if(!silent) showToast('⚠️ Escribe tu nombre primero','error'); return false; }
  if(!fbReady){ if(!silent) showToast('⚠️ Firebase no conectado','error'); return false; }
  try {
    const snap = await window._fb.cargar(nombre);
    if(!snap){ if(!silent) showToast('No se encontró quiniela para ' + nombre,'error'); return false; }
    state = migrateOldKeys({...snap.data});
    state.participante = nombre;
    localStorage.setItem('q2026_local', JSON.stringify(state));
    renderGrupos(); renderAllRondas(); populateCampeonSelect();
    document.getElementById('participanteInput').value = nombre;
    if(state.goleador) document.getElementById('goleadorInput').value = state.goleador;
    updateProgress();
    // Refrescar también la pestaña Hoy si existe
    if (typeof renderHoy === 'function') renderHoy();
    if(!silent) showToast('✅ Quiniela de ' + nombre + ' cargada desde la nube');
    return true;
  } catch(e){
    if(!silent) showToast('❌ Error al cargar: '+e.message,'error');
    return false;
  }
}

