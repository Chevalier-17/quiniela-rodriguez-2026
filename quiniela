async function adminCargar(){
  const content=document.getElementById('adminContent');
  content.innerHTML=`<div class="empty-state"><div class="emoji">⏳</div><p>Cargando quinielas…</p></div>`;
  if(!fbReady){
    content.innerHTML=`<div class="empty-state"><div class="emoji">⚠️</div><p>Firebase no conectado.<br>Revisa la configuración.</p></div>`;
    return;
  }
  try {
    const quinielas=await window._fb.listarTodos();
    if(!quinielas.length){
      content.innerHTML=`<div class="empty-state"><div class="emoji">📭</div><p>Todavía no hay quinielas guardadas.</p></div>`;
      return;
    }

    // Calcular puntos de cada quiniela (placeholder — suma marcadores llenados)
    const withPts = quinielas.map(q=>{
      const d = q.data||{};
      let pts=0, marcadores=0, ganadores=0;
      // Contamos campos llenados como proxy de puntos (se expandirá cuando captures resultados reales)
      GRUPOS.forEach(g=>g.p.forEach((p,pi)=>{
        const kL=`g${g.l}_${pi}_L`, kV=`g${g.l}_${pi}_V`;
        if(d[kL]!==undefined&&d[kL]!==''&&d[kV]!==undefined&&d[kV]!=='') marcadores++;
      }));
      return {...q, pts, marcadores};
    }).sort((a,b)=>b.marcadores-a.marcadores);

    const maxM = Math.max(...withPts.map(q=>q.marcadores),1);

    let html=`<table class="quinielas-table">
      <thead><tr>
        <th>#</th><th>Participante</th><th>Marcadores completados</th><th>Guardado</th><th>Acciones</th>
      </tr></thead><tbody>`;

    withPts.forEach((q,idx)=>{
      const fecha = q.updatedAt?.seconds
        ? new Date(q.updatedAt.seconds*1000).toLocaleDateString('es-MX',{day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'})
        : '—';
      const pct = Math.round((q.marcadores/72)*100); // 72 partidos de grupo
      const esOficial = PARTICIPANTES.some(p => p.trim().toLowerCase() === (q.participante||'').trim().toLowerCase());
      const warnBadge = esOficial ? '' : `<span style="font-size:9px;background:rgba(255,152,0,.15);color:#ff9800;padding:1px 6px;border-radius:3px;margin-left:6px;font-weight:700">⚠️ No está en la lista oficial — posible duplicado</span>`;
      html+=`<tr>
        <td style="font-weight:700;color:${idx===0?'var(--dorado)':'var(--gris)'}">${idx+1}</td>
        <td>
          <div class="participante-name">${q.participante||q.id}${warnBadge}</div>
          <div class="q-fecha">${fecha}</div>
        </td>
        <td>
          <div style="font-weight:700;font-size:14px">${q.marcadores}<span style="font-size:11px;color:var(--gris)">/72</span></div>
          <div class="ranking-bar"><div class="ranking-fill" style="width:${pct}%"></div></div>
        </td>
        <td class="q-fecha">${fecha}</td>
        <td>
          <button class="btn-ver" onclick="adminVerQuiniela('${q.id}')">👁 Ver</button>
          <button class="btn-ver" style="border-color:rgba(255,214,0,.3);color:var(--dorado)"
            onclick="adminVerHistorial('${q.participante||q.id}')">🕐 Historial</button>
          <button class="btn-del" onclick="adminEliminar('${q.id}','${q.participante||q.id}')">🗑 Borrar</button>
        </td>
      </tr>`;
    });
    html+='</tbody></table>';
    content.innerHTML=html;
  } catch(e){
    content.innerHTML=`<div class="empty-state"><div class="emoji">❌</div><p>Error: ${e.message}</p></div>`;
  }
}

