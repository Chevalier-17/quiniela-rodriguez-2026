function renderHoy() {
  const div = document.getElementById('hoyContent');
  const now = new Date();
  const hoy = now.toISOString().slice(0,10); // YYYY-MM-DD local... use CDMX

  // Get today in CDMX
  const cdmxNow = new Date(now.toLocaleString('en-US', {timeZone:'America/Mexico_City'}));
  const cdmxDateStr = cdmxNow.getFullYear() + '-' +
    String(cdmxNow.getMonth()+1).padStart(2,'0') + '-' +
    String(cdmxNow.getDate()).padStart(2,'0');

  // Collect today's matches — grupos + eliminatorias
  const todayPartidos = [];
  GRUPOS.forEach(g => {
    g.p.forEach((p, pi) => {
      if (p.dt && p.dt.slice(0,10) === cdmxDateStr) {
        todayPartidos.push({...p, pi, grupo: g.l, ge: g.e, tipo:'grupo'});
      }
    });
  });
  // Eliminatorias con fecha definida
  const elimRondas = [
    {prefix:'r32', partidos:BRACKET.r32, label:'Dieciseisavos'},
    {prefix:'r16', partidos:BRACKET.r16, label:'Octavos'},
    {prefix:'qf',  partidos:BRACKET.qf,  label:'Cuartos'},
    {prefix:'sf',  partidos:BRACKET.sf,  label:'Semis'},
    {prefix:'fin', partidos:BRACKET.final,label:'Final'},
  ];
  elimRondas.forEach(r => {
    (r.partidos||[]).forEach((p, i) => {
      if (p.dt && p.dt.slice(0,10) === cdmxDateStr) {
        todayPartidos.push({...p, pi: i, prefix: r.prefix, rondaLabel: r.label, tipo:'elim'});
      }
    });
  });
  todayPartidos.sort((a,b) => (a.dt||'').localeCompare(b.dt||''));

  const dias = ['Domingo','Lunes','Martes','Miércoles','Jueves','Viernes','Sábado'];
  const meses = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
  const fechaLabel = `${dias[cdmxNow.getDay()]} ${cdmxNow.getDate()} de ${meses[cdmxNow.getMonth()]} ${cdmxNow.getFullYear()}`;

  let html = `<div style="padding:0 0 16px">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px">
      <div class="hoy-header">📅 Partidos de Hoy</div>
      <div class="autoload-indicator"><span class="autoload-dot"></span> Auto-actualización activa</div>
    </div>
    <div class="hoy-fecha">${fechaLabel}</div>`;

  if (!todayPartidos.length) {
    html += `<div class="hoy-empty">😴 No hay partidos hoy.<br>Revisa la pestaña de Grupos para los próximos.</div>`;
  } else {
    todayPartidos.forEach(p => {
      const matchTime = new Date(p.dt + '-06:00');
      const diffMs = matchTime - now;
      const locked = isLocked(p.dt);

      // Keys y equipos según tipo
      let eL, eV, kL, kV, bid, vL, vV;
      if (p.tipo === 'grupo') {
        eL = p.ge.find(x=>x.n===p.a)||{f:'🌍',n:p.a};
        eV = p.ge.find(x=>x.n===p.b)||{f:'🌍',n:p.b};
        kL = `g${p.grupo}_${p.pi}_L`;
        kV = `g${p.grupo}_${p.pi}_V`;
        bid = `hoy_bg_${p.grupo}_${p.pi}`;
        vL = state[kL]??'';
        vV = state[kV]??'';
      } else {
        // Elim: equipos fijos o del estado
        const tA = p.a || resultadosReales[`${p.prefix}_${p.pi}_teamA`] || '?';
        const tB = p.b || resultadosReales[`${p.prefix}_${p.pi}_teamB`] || '?';
        eL = {f: flagFor(tA), n: tA};
        eV = {f: flagFor(tB), n: tB};
        kL = `${p.prefix}_${p.pi}_sL`;
        kV = `${p.prefix}_${p.pi}_sV`;
        bid = `hoy_elim_${p.prefix}_${p.pi}`;
        vL = state[kL]??'';
        vV = state[kV]??'';
      }

      // Format hour 12hrs
      const horaStr = fmt12(matchTime) + ' CDMX';

      // Countdown
      let countdownHTML = '';
      if (diffMs > 0) {
        const hrs = Math.floor(diffMs/3600000);
        const mins = Math.floor((diffMs%3600000)/60000);
        const secs = Math.floor((diffMs%60000)/1000);
        const countStr = hrs > 0 ? `${hrs}h ${mins}m` : `${mins}m ${secs}s`;
        countdownHTML = `<span class="hoy-countdown upcoming" id="cd_${p.grupo}_${p.pi}">⏱ ${countStr}</span>`;
      } else if (diffMs > -6300000) { // within 105 min = likely live
        countdownHTML = `<span class="hoy-countdown live">🔴 EN VIVO</span>`;
      } else {
        countdownHTML = `<span class="hoy-countdown done">✅ Terminado</span>`;
      }

      // Keys for save status and penalty
      const isElim = p.tipo === 'elim';
      const saveId = isElim ? `${p.prefix}_${p.pi}` : `${p.grupo}_${p.pi}`;
      const onInputL = isElim
        ? `setElimScoreHoy('${kL}','${kV}','${bid}','hoy_pen_${saveId}',this.value,false,'${isElim?p.prefix+"_"+p.pi:""}')`
        : `setGrupoScoreHoy('${kL}','${kV}','${bid}',this.value,false,'${saveId}')`;
      const onInputV = isElim
        ? `setElimScoreHoy('${kV}','${kL}','${bid}','hoy_pen_${saveId}',this.value,true,'${isElim?p.prefix+"_"+p.pi:""}')`
        : `setGrupoScoreHoy('${kV}','${kL}','${bid}',this.value,true,'${saveId}')`;
      const isTieNow = vL!==''&&vV!==''&&parseInt(vL)===parseInt(vV)&&!isNaN(parseInt(vL));
      const kPenHoy = `${isElim?p.prefix+'_'+p.pi:''}${isElim?'_pen':''}`;
      const vPenHoy = isElim ? (state[`${p.prefix}_${p.pi}_pen`]??'') : '';
      const penOptsHoy = isElim ? (`<option value="">— ¿Quién gana? —</option>` +
        [eL.n, eV.n].filter(n=>n&&n!=='?').map(e=>`<option value="${e}">${flagFor(e)} ${e}</option>`).join('')) : '';
      const headerLabel = isElim
        ? `${p.rondaLabel||'Elim'}`
        : `M${p.m} · Grupo ${p.grupo}`;

      html += `<div class="hoy-partido">
        <div class="hoy-partido-header">
          <span class="hoy-partido-num">${headerLabel}</span>
          ${countdownHTML}
        </div>
        <div class="hoy-equipos">
          <div class="hoy-team">
            <span class="hoy-flag">${eL.f}</span>
            <div><div class="hoy-name">${eL.n}</div><div class="hoy-hora">${horaStr}</div></div>
          </div>
          <div class="hoy-score-center">
            <div class="hoy-score-inputs">
              <input class="score-input" type="number" min="0" max="20"
                value="${vL}" placeholder="–" ${locked?'disabled':''}
                oninput="${onInputL}"
                style="width:38px;height:36px;font-size:16px">
              <span class="score-sep">:</span>
              <input class="score-input" type="number" min="0" max="20"
                value="${vV}" placeholder="–" ${locked?'disabled':''}
                oninput="${onInputV}"
                style="width:38px;height:36px;font-size:16px">
            </div>
            <div id="${bid}">${isElim?getElimBadge(vL,vV):getBadgeHTML(vL,vV)}</div>
            ${isElim ? `<div id="hoy_pen_${saveId}" style="${isTieNow?'':'display:none'}">
              <div style="font-size:10px;color:var(--dorado);font-weight:700;margin-top:4px">🥅 Penales:</div>
              <select class="select-equipo" style="font-size:11px;border-color:rgba(255,214,0,.4);margin-top:3px"
                onchange="setVal('${p.prefix}_${p.pi}_pen',this.value);setVal('${p.prefix}_${p.pi}_g',this.value)"
                ${locked?'disabled':''}>${penOptsHoy}</select>
            </div>` : ''}
            <div id="save_${saveId}">
              ${vL!==''&&vV!==''?'<span class="save-status saved">✅ Guardado</span>':''}
            </div>
            ${locked?'<div class="hoy-locked-badge">🔒 Cerrado</div>':''}
          </div>
          <div class="hoy-team right">
            <span class="hoy-flag">${eV.f}</span>
            <div><div class="hoy-name">${eV.n}</div></div>
          </div>
        </div>
      </div>`;
    });
  }

  html += '</div>';
  div.innerHTML = html;

  // Start countdown ticker
  clearInterval(window._hoyTimer);
  window._hoyTimer = setInterval(() => {
    const now2 = new Date();
    todayPartidos.forEach(p => {
      const el = document.getElementById(`cd_${p.grupo}_${p.pi}`);
