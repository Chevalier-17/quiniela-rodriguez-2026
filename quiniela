// MIGRACIÓN: keys antiguas (gA_0_1_L) → nuevas (gA_0_L)
// ══════════════════════════════════════════════════════
function migrateOldKeys(st) {
  let migrated = false;
  GRUPOS.forEach(g => {
    const equipos = g.e.map(e => e.n);
    for (let li = 0; li < equipos.length; li++) {
      for (let vi = li+1; vi < equipos.length; vi++) {
        const oldKL = `g${g.l}_${li}_${vi}_L`;
        const oldKV = `g${g.l}_${li}_${vi}_V`;
        if (st[oldKL] !== undefined || st[oldKV] !== undefined) {
          const teamA = equipos[li], teamB = equipos[vi];
          const pi = g.p.findIndex(p =>
            (p.a === teamA && p.b === teamB) ||
            (p.a === teamB && p.b === teamA)
          );
          if (pi !== -1) {
            const newKL = `g${g.l}_${pi}_L`;
            const newKV = `g${g.l}_${pi}_V`;
            if (st[newKL] === undefined) {
              const p = g.p[pi];
              // Respetar qué equipo va en cada lado
              if (p.a === teamA) {
                st[newKL] = st[oldKL]; st[newKV] = st[oldKV];
              } else {
                st[newKL] = st[oldKV]; st[newKV] = st[oldKL]; // invertido
              }
              delete st[oldKL]; delete st[oldKV];
              migrated = true;
            }
          }
        }
      }
    }
  });
  if (migrated) localStorage.setItem('q2026_local', JSON.stringify(st));
  return st;
}


// ══════════════════════════════════════════════════════
// SISTEMA DE PUNTOS
// 1 pt → ganador correcto (grupo)
// 3 pts → marcador exacto (grupo)
// 2 pts → ganador correcto (eliminatorias)
// 5 pts → marcador exacto (eliminatorias)
// ══════════════════════════════════════════════════════
let resultadosReales = {}; // { matchKey: {gL, gV} }

// matchKey for grupos: "g{L}_{pi}"
// matchKey for elim: "{prefix}_{i}"

function calcPuntosParticipante(qData, resultados) {
  let pts = 0, exactos = 0, ganadores = 0;

  // Fase de grupos
  GRUPOS.forEach(g => {
    g.p.forEach((p, pi) => {
      const key = `g${g.l}_${pi}`;
      const real = resultados[key];
      if (!real || real.gL === '' || real.gV === '') return;
      const rL = parseInt(real.gL), rV = parseInt(real.gV);
      const qL = parseInt(qData[`g${g.l}_${pi}_L`] ?? '');
      const qV = parseInt(qData[`g${g.l}_${pi}_V`] ?? '');
      if (isNaN(qL) || isNaN(qV)) return;
      // Resultado real
      const realGana = rL > rV ? 'L' : rL < rV ? 'V' : 'E';
      const qGana   = qL > qV ? 'L' : qL < qV ? 'V' : 'E';
      if (qL === rL && qV === rV) { pts += 3; exactos++; }
      else if (qGana === realGana) { pts += 1; ganadores++; }
    });
  });

  // Eliminatorias — reglas nuevas:
  // 2 pts por acertar quién avanza (independiente del marcador)
  // +3 pts adicionales si además acertó el marcador exacto (antes de penales)
  // Máximo 5 pts por partido. Casos especiales:
  // - Empate en pronóstico + ganador correcto en penales = 2 pts (o 5 si marcador exacto)
  // - Empate en marcador real, pronóstico acertó empate pero equipo equivocado = 3 pts (solo marcador)
  const rondasElim = [
    {prefix:'r32', n:16}, {prefix:'r16', n:8},
    {prefix:'qf',  n:4},  {prefix:'sf',  n:2}, {prefix:'fin', n:2}
  ];
  rondasElim.forEach(r => {
    for (let i = 0; i < r.n; i++) {
      const key = `${r.prefix}_${i}`;
      const real = resultados[key];
      if (!real) continue;

      const rL = parseInt(real.gL ?? '');
      const rV = parseInt(real.gV ?? '');
      if (isNaN(rL) || isNaN(rV)) continue;

      // Ganador real: por marcador si no hay empate, por penales si empate
      const rondaMap = {r32:BRACKET.r32, r16:BRACKET.r16, qf:BRACKET.qf, sf:BRACKET.sf, fin:BRACKET.final};
      const partido = rondaMap[r.prefix]?.[i];
      let realGanador = null;
      if (rL !== rV) {
        realGanador = rL > rV ? (partido?.a || null) : (partido?.b || null);
      } else if (real.ganador) {
        realGanador = real.ganador; // definido por penales
      }
      if (!realGanador) continue;

      // Pronóstico del participante
      const qL = parseInt(qData[`${r.prefix}_${i}_sL`] ?? '');
      const qV = parseInt(qData[`${r.prefix}_${i}_sV`] ?? '');
      const qEmpate = !isNaN(qL) && !isNaN(qV) && qL === qV;
      // Ganador pronosticado: si marcador Q no empate → inferir por score; si empate → campo pen/g
      const qPen = qData[`${r.prefix}_${i}_pen`] || qData[`${r.prefix}_${i}_g`] || null;
      let qGanador = null;
      if (!isNaN(qL) && !isNaN(qV) && qL !== qV) {
        qGanador = qL > qV ? (partido?.a || null) : (partido?.b || null);
      } else if (qEmpate && qPen) {
        qGanador = qPen;
      }

      const aciertoMarcador = !isNaN(qL) && !isNaN(qV) && qL === rL && qV === rV;
      const aciertoGanador  = qGanador && qGanador === realGanador;

      if (aciertoGanador && aciertoMarcador) { pts += 5; exactos++; ganadores++; }
      else if (aciertoGanador)               { pts += 2; ganadores++; }
      else if (aciertoMarcador)              { pts += 3; exactos++; } // empate correcto, equipo equivocado
    }
  });

  return { pts, exactos, ganadores };
}

