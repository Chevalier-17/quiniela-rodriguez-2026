// Variante para la pestaña "Hoy": además auto-guarda en la nube (debounced)
// y muestra estado visual verde/naranja
let _autosaveTimers = {};
let _savePending = false; // true mientras hay un save en curso o timer activo

function setGrupoScoreHoy(kC,kO,bid,val,otherIsLocal,matchId){
  setGrupoScore(kC,kO,bid,val,otherIsLocal);

  const statusEl = document.getElementById('save_'+matchId);
  const vO = state[kO]??'';
  const vL = otherIsLocal?vO:val, vV = otherIsLocal?val:vO;

  if (vL==='' || vV==='') {
    if (statusEl) statusEl.innerHTML = '';
    return;
  }

  if (statusEl) statusEl.innerHTML = '<span class="save-status unsaved">🟠 Sin guardar</span>';
  _savePending = true;

  // Debounce: 800ms (más rápido que antes)
  clearTimeout(_autosaveTimers[matchId]);
  _autosaveTimers[matchId] = setTimeout(async () => {
    const nombre = document.getElementById('participanteInput').value.trim();
    if (!nombre) {
      if (statusEl) statusEl.innerHTML = '<span class="save-status unsaved">⚠️ Falta tu nombre arriba</span>';
      _savePending = false;
      return;
    }
    if (!fbReady) {
      if (statusEl) statusEl.innerHTML = '<span class="save-status unsaved">🟠 Sin conexión — local ok</span>';
      _savePending = false;
      return;
    }
    try {
      state = migrateOldKeys(state);
      state.participante = nombre;
      await window._fb.guardar(nombre, state);
      if (statusEl) statusEl.innerHTML = '<span class="save-status saved">✅ Guardado</span>';
    } catch(e) {
      if (statusEl) statusEl.innerHTML = '<span class="save-status unsaved">⚠️ Error al guardar</span>';
    } finally {
      _savePending = false;
      _autosaveTimers[matchId] = null;
    }
  }, 800);
}

function getBadgeHTML(vL,vV){
  if(vL===''||vV==='') return '';
  const l=parseInt(vL),v=parseInt(vV);
  if(isNaN(l)||isNaN(v)) return '';
  if(l>v) return `<span class="resultado-badge badge-local">← Gana local</span>`;
  if(v>l) return `<span class="resultado-badge badge-visita">Gana visita →</span>`;
  return `<span class="resultado-badge badge-empate">Empate</span>`;
}


