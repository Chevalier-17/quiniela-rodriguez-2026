@keyframes blink{0%,100%{opacity:1}50%{opacity:.5}}
.hoy-equipos{display:flex;align-items:center;gap:8px;padding:12px 14px}
.hoy-team{flex:1;display:flex;align-items:center;gap:7px}
.hoy-team.right{flex-direction:row-reverse;text-align:right}
.hoy-flag{font-size:22px;flex-shrink:0}
.hoy-name{font-size:13px;font-weight:700;line-height:1.2}
.hoy-hora{font-size:11px;color:var(--gris);margin-top:1px}
.hoy-score-center{display:flex;flex-direction:column;align-items:center;flex-shrink:0;gap:2px}
.hoy-score-inputs{display:flex;align-items:center;gap:4px}
.hoy-locked-badge{font-size:10px;color:#f55;font-weight:700;margin-top:2px}

/* ── BRACKET ADMIN ── */
.bracket-ronda{margin-bottom:28px}
.bracket-ronda-title{font-family:'Bebas Neue',sans-serif;font-size:18px;color:var(--verde);
  letter-spacing:1px;margin-bottom:12px;padding-bottom:6px;border-bottom:1px solid var(--borde)}
.bracket-partido{background:var(--panel);border:1px solid var(--borde);border-radius:8px;
  padding:12px;margin-bottom:8px}
.bracket-partido-num{font-size:10px;font-weight:700;color:var(--gris);text-transform:uppercase;
  letter-spacing:.7px;margin-bottom:8px}
.bracket-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.bracket-select{flex:1;min-width:120px;background:#111;border:1.5px solid var(--borde);
  color:var(--blanco);padding:7px 8px;border-radius:6px;font-size:12px;
  font-family:'Inter',sans-serif;cursor:pointer;appearance:none}
.bracket-select:focus{outline:none;border-color:var(--verde)}
.bracket-select.filled{border-color:rgba(0,200,83,.5)}
.bracket-vs{font-size:11px;font-weight:700;color:var(--gris);flex-shrink:0}
.bracket-dt-input{background:#111;border:1.5px solid var(--borde);color:var(--blanco);
  padding:7px 8px;border-radius:6px;font-size:12px;font-family:'Inter',sans-serif;
  width:180px;cursor:pointer}
.bracket-dt-input:focus{outline:none;border-color:var(--verde)}
.bracket-dt-input.filled{border-color:rgba(0,200,83,.5)}
.bracket-save-btn{background:var(--verde);color:var(--negro);border:none;
  padding:10px 20px;border-radius:6px;font-size:13px;font-weight:700;
  font-family:'Inter',sans-serif;cursor:pointer;margin-top:12px;width:100%}
.bracket-save-btn:hover{background:#00e65c}
.bracket-status{font-size:11px;margin-top:6px;display:flex;align-items:center;gap:6px}
.bracket-set{color:var(--verde)}
.bracket-unset{color:var(--gris)}

/* ── ADMIN TABS ── */
.admin-tabs{display:flex;gap:0;border-bottom:1px solid var(--borde);margin-bottom:20px}
.admin-tab{padding:10px 18px;font-size:12px;font-weight:600;color:var(--gris);cursor:pointer;
  border-bottom:2px solid transparent;white-space:nowrap;transition:all .2s;user-select:none}
.admin-tab:hover{color:var(--blanco)}
.admin-tab.active{color:var(--dorado);border-bottom-color:var(--dorado)}

/* ── RESULTADOS REALES ── */
.real-grupo{margin-bottom:24px}
.real-grupo-title{font-size:11px;font-weight:700;color:var(--gris);text-transform:uppercase;
  letter-spacing:1px;margin-bottom:8px;padding-bottom:6px;border-bottom:1px solid var(--borde)}
.real-partido{display:flex;align-items:center;gap:8px;padding:7px 10px;
  background:var(--panel);border:1px solid var(--borde);border-radius:6px;margin-bottom:5px}
.real-equipos{display:flex;align-items:center;gap:6px;flex:1;min-width:0}
.real-team{font-size:12px;font-weight:600;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.real-team.right{text-align:right}
.real-score-box{display:flex;align-items:center;gap:3px;flex-shrink:0}
.real-score-input{width:34px;height:30px;background:#111;border:1.5px solid var(--borde);
  color:var(--blanco);text-align:center;font-size:14px;font-weight:700;
  font-family:'Inter',sans-serif;border-radius:5px;-moz-appearance:textfield}
.real-score-input::-webkit-inner-spin-button{-webkit-appearance:none}
.real-score-input:focus{outline:none;border-color:var(--dorado);background:#1a1500}
.real-saved{font-size:9px;color:var(--verde);margin-left:4px;opacity:0}
.real-saved.show{opacity:1;transition:opacity .3s}

/* ── PODIO ── */
.podio-wrap{margin-bottom:32px}
.podio-title{font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--dorado);
  letter-spacing:1px;margin-bottom:16px}
.podio-grid{display:flex;gap:12px;align-items:flex-end;justify-content:center;margin-bottom:24px}
.podio-card{background:var(--panel);border:1px solid var(--borde);border-radius:12px;
  padding:16px 12px;text-align:center;flex:1;max-width:180px;transition:all .3s}
.podio-card.p1{border-color:var(--dorado);background:rgba(255,214,0,.06);min-height:160px}
.podio-card.p2{border-color:#90a4ae;background:rgba(144,164,174,.05);min-height:130px}
.podio-card.p3{border-color:#bf8970;background:rgba(191,137,112,.05);min-height:110px}
.podio-emoji{font-size:32px;margin-bottom:6px}
.podio-name{font-size:14px;font-weight:700;margin-bottom:4px}
.podio-pts{font-family:'Bebas Neue',sans-serif;font-size:36px;line-height:1}
.podio-pts.p1{color:var(--dorado)}
.podio-pts.p2{color:#90a4ae}
.podio-pts.p3{color:#bf8970}
.podio-pts-label{font-size:10px;color:var(--gris);text-transform:uppercase;letter-spacing:.5px}
.podio-breakdown{font-size:10px;color:var(--muted2);margin-top:4px}

/* ── RANKING TABLE ── */
.ranking-full{width:100%;border-collapse:collapse;font-size:13px}
.ranking-full th{text-align:left;padding:9px 10px;font-size:10px;font-weight:700;color:var(--gris);
  text-transform:uppercase;letter-spacing:.7px;border-bottom:2px solid var(--borde)}
.ranking-full td{padding:8px 10px;border-bottom:1px solid #1a1a1a;vertical-align:middle}
.ranking-full tr:hover td{background:rgba(255,255,255,.02)}
.pts-cell{font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--verde)}
.pts-breakdown{font-size:10px;color:var(--gris);white-space:nowrap}
.override-bar{background:rgba(255,214,0,.08);border:1px solid rgba(255,214,0,.2);
  border-radius:8px;padding:10px 14px;margin-bottom:16px;display:flex;align-items:center;gap:10px}
.override-label{font-size:12px;color:var(--dorado);font-weight:600}
.override-sub{font-size:11px;color:var(--gris)}
</style>
</head>
<body>

<!-- ═══════════════════════════════ HEADER ═══════════════════════════════ -->
<header>
  <div>
    <div class="logo">MUNDIAL <span>2026</span></div>
    <div class="familia-tag">Familia Rodríguez</div>
  </div>
  <div style="margin-left:12px">
    <div class="part-wrap">
      <div class="part-label">Participante</div>
      <select class="part-input" id="participanteInput" onchange="onParticipanteChange()">
        <option value="">— Elige tu nombre —</option>
      </select>
    </div>
  </div>
  <div class="header-right">
    <span class="fb-status fb-wait" id="fbStatus">⏳ Conectando…</span>
    <button class="btn btn-ghost" onclick="resetQuiniela()" title="Limpia la pantalla, no borra tu quiniela en la nube">🧹 Limpiar</button>
    <button class="btn btn-ghost" style="border-color:rgba(68,138,255,.4);color:#448aff" onclick="cargarDesdeNube()">📥 Cargar</button>
    <button class="btn btn-green" onclick="guardarEnNube()">☁️ Guardar</button>
    <button class="btn btn-admin" onclick="showTab('admin')">🔐 Admin</button>
  </div>
</header>

<!-- ═══════════════════════════════ TABS ═══════════════════════════════ -->
<div class="tabs">
  <div class="tab active"  onclick="showTab('hoy')">📅 Hoy</div>
  <div class="tab"         onclick="showTab('grupos')">⚽ Grupos</div>
  <div class="tab"         onclick="showTab('dieciseisavos')">Dieciseisavos</div>
  <div class="tab"         onclick="showTab('octavos')">Octavos</div>
  <div class="tab"         onclick="showTab('cuartos')">Cuartos</div>
  <div class="tab"         onclick="showTab('semis')">Semis</div>
  <div class="tab"         onclick="showTab('final')">🏆 Final</div>
  <div class="tab"         onclick="showTab('podio')">🥇 Podio</div>
  <div class="tab tab-admin" onclick="showTab('admin')">🔐 Admin</div>
</div>

<!-- ═══════════════════════════════ MAIN ═══════════════════════════════ -->
<div class="main">
<div class="progress-bar"><div class="progress-fill" id="progressFill" style="width:0%"></div></div>

<!-- GRUPOS -->
<!-- HOY -->
<div id="section-hoy">
  <div id="hoyContent"></div>
</div>

<!-- PODIO PUBLICO -->
<div id="section-podio" class="section-hidden">
  <div id="podioPublicoContent">
    <div class="empty-state"><div class="emoji">⏳</div><p>Cargando clasificación…</p></div>
  </div>
</div>

<div id="section-grupos">
  <div class="legend">
    <span class="legend-title">Puntos:</span>
    <div class="legend-item"><div class="lb lb-g">G</div><span class="legend-text">Ganador correcto → 1 pt</span></div>
    <div class="legend-item"><div class="lb lb-m">M</div><span class="legend-text">Marcador exacto → 3 pts</span></div>
  </div>
  <div class="grupos-grid" id="gruposGrid"></div>
</div>

<!-- OCTAVOS -->
<div id="section-dieciseisavos" class="section-hidden">
  <div class="elim-section">
    <div class="elim-title">⚽ Dieciseisavos de Final</div>
    <div class="ronda-grid" id="dieciseisavosGrid"></div>
  </div>
</div>

<!-- OCTAVOS -->
<div id="section-octavos" class="section-hidden">
  <div class="elim-section">
    <div class="elim-title">🔥 Octavos de Final</div>
    <div class="ronda-grid" id="octavosGrid"></div>
  </div>
</div>

<!-- CUARTOS -->
<div id="section-cuartos" class="section-hidden">
  <div class="elim-section">
    <div class="elim-title">⚡ Cuartos de Final</div>
    <div class="ronda-grid" id="cuartosGrid"></div>
  </div>
</div>

<!-- SEMIS -->
<div id="section-semis" class="section-hidden">
