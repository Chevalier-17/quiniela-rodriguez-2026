// Builds podio display given a ranked array (already sorted, with .rank assigned)
function buildPodioHTML(ranked, isAdmin=false) {
  const maxPts = Math.max(...ranked.map(r=>r.pts), 1);
  const medalFor = r => r===1?'🥇':r===2?'🥈':r===3?'🥉':'';
  const clsFor   = r => r===1?'p1':r===2?'p2':r===3?'p3':'';

  // Check if everyone is at 0
  const allZero = ranked.every(r => r.pts === 0);
  if (allZero) {
    const frases = [
      '⚽ Let the games begin.',
      '🌍 48 equipos. 1 campeón. ¿Quién lo adivinó?',
      '🏆 Todos en 0 — el torneo apenas empieza.',
      '🎯 Aún nadie lleva ventaja. Que gane el mejor pronóstico.',
      '🔥 Todo está por decidirse.',
    ];
    const frase = frases[Math.floor(Date.now()/60000) % frases.length];
    return `<div style="text-align:center;padding:48px 20px">
      <div style="font-size:52px;margin-bottom:16px">⚽</div>
      <div style="font-family:'Bebas Neue',sans-serif;font-size:28px;color:var(--dorado);
        letter-spacing:2px;margin-bottom:8px">${frase}</div>
      <div style="font-size:13px;color:var(--gris)">
        Los puntos aparecerán aquí conforme se jueguen los partidos.
      </div>
    </div>`;
  }

  // Regla: siempre mostrar mínimo 3 participantes en el podio.
  // Se llenan posiciones 1°, 2°, 3° en orden. Si hay empate en una posición,
  // se muestran TODOS los empatados. Se para cuando ya hay ≥3 personas mostradas
  // Y la última posición agregada está completa (no partimos un grupo de empatados).

  const rank1 = ranked.filter(r => r.rank === 1);
  const rank2 = ranked.filter(r => r.rank === 2);
  const rank3 = ranked.filter(r => r.rank === 3);

  let podioItems = [...rank1]; // siempre incluir todos los de 1°

  if (podioItems.length < 3 && rank2.length > 0) {
    podioItems = [...podioItems, ...rank2]; // agregar todos los de 2° completo
  }
  if (podioItems.length < 3 && rank3.length > 0) {
    podioItems = [...podioItems, ...rank3]; // agregar todos los de 3° completo
  }
  // Si aún hay menos de 3 (pocos participantes), quedará con los que hay

  // Visual order: 2nd place left, 1st place center, 3rd place right
  const byVisual = [
    ...podioItems.filter(r=>r.rank===2),
    ...podioItems.filter(r=>r.rank===1),
    ...podioItems.filter(r=>r.rank===3),
  ];

  let html = '<div class="podio-grid">';
  byVisual.forEach(r => {
    const cls = clsFor(r.rank);
    html += `<div class="podio-card ${cls}">
      <div class="podio-emoji">${medalFor(r.rank)}</div>
      <div class="podio-name">${r.nombre}</div>
      <div class="podio-pts ${cls}">${r.pts}</div>
      <div class="podio-pts-label">pts · ${r.rank}° lugar</div>
      <div class="podio-breakdown">✅ ${r.exactos} exactos · 🎯 ${r.ganadores} ganadores</div>
    </div>`;
  });
  html += '</div>';

  // Full table
  html += `<table class="ranking-full" style="margin-top:16px">
    <thead><tr>
      <th>#</th><th>Participante</th><th>Puntos</th><th>Exactos</th><th>Ganadores</th>
    </tr></thead><tbody>`;
  ranked.forEach(r => {
    const barW = Math.round((r.pts/maxPts)*100);
    const color = r.rank===1?'var(--dorado)':r.rank===2?'#90a4ae':r.rank===3?'#bf8970':'var(--gris)';
    html += `<tr>
      <td style="font-weight:700;color:${color}">${r.rank}</td>
      <td style="font-weight:700">${medalFor(r.rank)} ${r.nombre}</td>
      <td>
        <div style="display:flex;align-items:center;gap:8px">
          <div style="height:6px;width:70px;background:rgba(0,200,83,.1);border-radius:3px;overflow:hidden">
            <div style="height:100%;width:${barW}%;background:var(--verde);border-radius:3px"></div>
          </div>
          <span class="pts-cell">${r.pts}</span>
        </div>
      </td>
      <td><span style="color:var(--dorado);font-weight:700">${r.exactos}</span></td>
      <td><span style="color:var(--verde);font-weight:700">${r.ganadores}</span></td>
    </tr>`;
  });
  html += '</tbody></table>';
  return html;
}

function buildRanked(quinielas) {
  const sorted = quinielas
    .filter(q => q.participante)
    .map(q => {
      const d = migrateOldKeys({...(q.data||{})});
      const {pts, exactos, ganadores} = calcPuntosParticipante(d, resultadosReales);
      return {nombre: q.participante||q.id, pts, exactos, ganadores};
    })
    .sort((a,b) => b.pts-a.pts || b.exactos-a.exactos);

  let rankNum = 1;
  return sorted.map((r,i,arr) => {
    if (i>0 && (r.pts!==arr[i-1].pts || r.exactos!==arr[i-1].exactos)) rankNum = i+1;
    return {...r, rank: rankNum};
  });
}

