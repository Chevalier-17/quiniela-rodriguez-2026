  if (isTie && penDiv) {
    const currentA = state[`${prefix_i}_1`] || BRACKET.r32.find((_,ii) => `r32_${ii}` === prefix_i)?.a || '';
    const currentB = state[`${prefix_i}_2`] || BRACKET.r32.find((_,ii) => `r32_${ii}` === prefix_i)?.b || '';
