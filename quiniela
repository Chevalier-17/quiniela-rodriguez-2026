        <button class="btn btn-ghost" style="border-color:rgba(244,67,54,.4);color:#f77" onclick="adminDetectarDuplicados()">🔍 Detectar duplicados</button>
      </div>
      <div id="dupContent"></div>
      <div id="adminContent">
        <div class="empty-state"><div class="emoji">⏳</div><p>Cargando quinielas…</p></div>
